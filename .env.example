# ---- Frontend (Vite / AI Studio) ----
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ============================================================
# BACKEND (Express + Prisma + TiDB Cloud)
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:3000

# ---- Database: TiDB Cloud (MySQL-compatible) ----
# Get this from TiDB Cloud > Cluster > "Connect" > select Prisma.
# Example:
# mysql://USER.cluster:PASSWORD@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/sofia_shop?sslaccept=strict
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/sofia_shop?sslaccept=strict"

# ---- JWT ----
# Generate strong random values for production. Example:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=replace-with-long-random-string-min-16-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-16
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Crypto ----
BCRYPT_ROUNDS=10

# ---- RajaOngkir / Komerce (online-order shipping cost) ----
# Get an API key from the Komerce dashboard (Developer > Settings > "Shipping Cost").
# Leave RAJAONGKIR_API_KEY empty to disable the shipping/ongkir feature.
RAJAONGKIR_API_KEY=
# Komerce RajaOngkir API v1 base URL (same host for sandbox & production keys).
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
# Couriers to quote, colon-separated.
RAJAONGKIR_COURIERS=jne:jnt:sicepat:anteraja:pos:tiki:ninja

# ---- Seed (used by `npm run seed`) ----
SEED_ADMIN_EMAIL=admin@sofiashop.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# ---- Frontend (Vite / AI Studio) ----
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ============================================================
# BACKEND (Express + Prisma + TiDB Cloud)
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:3000

# ---- Database: TiDB Cloud (MySQL-compatible) ----
# Get this from TiDB Cloud > Cluster > "Connect" > select Prisma.
# Example:
# mysql://USER.cluster:PASSWORD@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/sofia_shop?sslaccept=strict
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/sofia_shop?sslaccept=strict"

# ---- JWT ----
# Generate strong random values for production. Example:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=replace-with-long-random-string-min-16-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-16
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Crypto ----
BCRYPT_ROUNDS=10

# ---- RajaOngkir V2 (Komerce) — ongkir + waybill tracking ----
# "Shipping Cost" API key from the Komerce dashboard. Host rajaongkir.komerce.id,
# auth header `key`. Powers ongkir calculation, destination search, AWB tracking.
# Empty = ongkir feature disabled.
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
RAJAONGKIR_COURIERS=jne:jnt:sicepat:anteraja:pos:tiki:ninja

# ---- Komship Delivery Order API (collaborator) — auto-generate resi/AWB ----
# SEPARATE "Shipping Delivery" key (header x-api-key) — NOT the Shipping Cost key.
# Sandbox by default; for production: https://api.collaborator.komerce.id/order/api/v1
# Empty KOMSHIP_API_KEY = keep manual resi entry (no auto-resi button).
KOMSHIP_BASE_URL=https://api-sandbox.collaborator.komerce.id/order/api/v1
KOMSHIP_API_KEY=
# Default pickup vehicle (Motor | Mobil | Truk) and time (HH:MM).
KOMSHIP_PICKUP_VEHICLE=Motor
KOMSHIP_PICKUP_TIME=13:00

# ---- Seed (used by `npm run seed`) ----
SEED_ADMIN_EMAIL=admin@sofiashop.local
SEED_ADMIN_PASSWORD=ChangeMe123!

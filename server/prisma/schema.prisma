// Sofia Shop POS - Prisma schema (multi-tenant)
// Target: TiDB Cloud (MySQL-compatible)
//
// TiDB does not support foreign key constraints in the traditional sense,
// so referential integrity is enforced at the application layer.
// `relationMode = "prisma"` makes Prisma emulate FK behavior client-side.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
}

enum TransactionStatus {
  PENDING
  PAID
  VOIDED
  REFUNDED
}

enum TransactionChannel {
  POS
  ONLINE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  EWALLET
  QRIS
  OTHER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum OnlineOrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  customDomain String?  @unique
  description  String?  @db.Text
  whatsapp     String?
  email        String?
  address      String?  @db.Text
  logoUrl      String?  @db.LongText
  bankInfo     String?  @db.Text
  // shipping origin (RajaOngkir/Komerce destination id + name snapshot) for online-order ongkir
  originCityId   String?
  originCityName String?
  // full origin address breakdown (RajaOngkir hierarchy) for complete store address
  originProvince    String?
  originCity        String?
  originDistrict    String?
  originSubdistrict String?
  originZipCode     String?
  // sender contact used on shipping labels / courier pickup
  senderName  String?
  senderPhone String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  members        Member[]
  transactions   Transaction[]
  stockMovements StockMovement[]
  activityLogs   ActivityLog[]

  @@index([slug])
  @@index([customDomain])
}

model User {
  id           String   @id @default(cuid())
  // null for SUPER_ADMIN; required for tenant-scoped roles
  tenantId     String?
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CASHIER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant?         @relation(fields: [tenantId], references: [id])
  refreshTokens  RefreshToken[]
  transactions   Transaction[]
  stockMovements StockMovement[]
  activityLogs   ActivityLog[]

  @@index([tenantId])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  sku         String
  barcode     String?
  description String?  @db.Text
  imageUrl    String?  @db.LongText
  // price in IDR rupiah (no decimals needed for IDR, but keep decimal for safety)
  price       Decimal  @db.Decimal(14, 2)
  costPrice   Decimal  @db.Decimal(14, 2) @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  unit        String   @default("pcs")
  // shipping weight in grams; used to calculate ongkir for online orders
  weight      Int      @default(1000)
  isActive    Boolean  @default(true)
  showOnline  Boolean  @default(true)
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  category         Category?         @relation(fields: [categoryId], references: [id])
  transactionItems TransactionItem[]
  stockMovements   StockMovement[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([categoryId])
  @@index([sku])
  @@index([barcode])
  @@index([isActive])
}

model Member {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  email     String?
  address   String?  @db.Text
  points    Int      @default(0)
  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  transactions Transaction[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
  @@index([name])
}

model Transaction {
  id                String             @id @default(cuid())
  tenantId          String
  transactionNumber String             @unique
  channel           TransactionChannel @default(POS)
  status            TransactionStatus  @default(PAID)
  paymentMethod     PaymentMethod      @default(CASH)

  cashierId String?
  memberId  String?

  // online-order-only fields (nullable for POS)
  customerName    String?
  customerPhone   String?
  shippingAddress String?  @db.Text
  onlineStatus    OnlineOrderStatus?

  // online-order shipping/courier details (RajaOngkir)
  shippingCourier String? // courier code/name, e.g. "jne"
  shippingService String? // service code, e.g. "REG"
  shippingEtd     String? // estimated delivery, e.g. "2-3"
  destinationCity String? // destination city name snapshot
  destinationId   String? // Komerce destination id of the receiver (for Komship order)
  trackingNumber  String? // resi / AWB number for shipment tracking
  shipmentOrderNo String? // Komship order number (order_no) once a shipment is created
  labelUrl        String? @db.Text // Komship live tracking / label URL
  shippedAt       DateTime? // when the order was marked SHIPPED

  // online payment confirmation (buyer uploads proof, admin verifies on the web)
  paymentProofUrl    String?   @db.LongText // base64 data URL of the buyer's payment proof
  paymentProofAt     DateTime? // when the buyer submitted the proof
  paymentConfirmedAt DateTime? // when an admin confirmed the payment as received

  subtotal      Decimal @db.Decimal(14, 2)
  discount      Decimal @db.Decimal(14, 2) @default(0)
  tax           Decimal @db.Decimal(14, 2) @default(0)
  shippingFee   Decimal @db.Decimal(14, 2) @default(0)
  total         Decimal @db.Decimal(14, 2)
  paymentAmount Decimal @db.Decimal(14, 2) @default(0)
  changeAmount  Decimal @db.Decimal(14, 2) @default(0)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  cashier        User?             @relation(fields: [cashierId], references: [id])
  member         Member?           @relation(fields: [memberId], references: [id])
  items          TransactionItem[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([cashierId])
  @@index([memberId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  productId     String
  productName   String // snapshot
  sku           String // snapshot
  quantity      Int
  unitPrice     Decimal @db.Decimal(14, 2)
  unitCost      Decimal @db.Decimal(14, 2) @default(0)
  discount      Decimal @db.Decimal(14, 2) @default(0)
  subtotal      Decimal @db.Decimal(14, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model ActivityLog {
  id         String    @id @default(cuid())
  // null for platform-level (SUPER_ADMIN) actions
  tenantId   String?
  userId     String?
  // snapshots so the log stays readable even if the user is deleted
  userEmail  String?
  userRole   UserRole?
  action     String // e.g. "product.create", "auth.login"
  entityType String? // e.g. "Product", "Transaction"
  entityId   String?
  summary    String  @db.Text // human-readable, Indonesian
  metadata   String? @db.Text // optional JSON string
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model StockMovement {
  id            String            @id @default(cuid())
  tenantId      String
  productId     String
  type          StockMovementType
  quantity      Int // positive integer; direction implied by type
  stockBefore   Int
  stockAfter    Int
  reference     String? // free text e.g. "PO-0001"
  transactionId String?
  userId        String?
  note          String?           @db.Text
  createdAt     DateTime          @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([transactionId])
  @@index([userId])
  @@index([createdAt])
}
